{"sections":{"main":{"type":"main-product","blocks":{"title":{"type":"title","settings":{}},"price":{"type":"price","settings":{"show_tax_and_shipping":false,"enable_product_reviews_by_price":true}},"divider_wDWKft":{"type":"divider","settings":{"show_in_quickbuy":false}},"description":{"type":"description","settings":{"show_in_tab":false,"open_tab":false,"icon":"","show_in_quickbuy":false}},"divider":{"type":"divider","settings":{"show_in_quickbuy":false}},"variant-picker":{"type":"variant-picker","settings":{"show_single":false,"selector_style":"dropdown","dynamic_availability":"show","enable_size_chart":false,"size_chart_label":"","size_chart_variant":"Size","size_chart_page":""}},"custom_liquid_eAK7Gg":{"type":"custom-liquid","settings":{"custom_liquid":"<div class=\"am-variant-specs\" id=\"am-variant-specs-{{ section.id }}\"\n     style=\"display:flex; gap:32px; align-items:center; flex-wrap:wrap; margin-top:18px; color:#5E7361; font-size:0.95rem;\">\n\n  <!-- Diameter -->\n  <div style=\"display:flex; align-items:center; gap:8px;\">\n    <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\"\n         stroke=\"#5E7361\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n      <circle cx=\"12\" cy=\"12\" r=\"8.5\"\/>\n      <line x1=\"7.2\" y1=\"16.8\" x2=\"16.8\" y2=\"7.2\"\/>\n    <\/svg>\n    <span data-k=\"diameter\">–<\/span>\n  <\/div>\n\n  <!-- Hoogte -->\n  <div style=\"display:flex; align-items:center; gap:8px;\">\n    <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\"\n         stroke=\"#5E7361\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n      <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"\/>\n      <polyline points=\"10,7 12,5 14,7\"\/>\n      <polyline points=\"10,17 12,19 14,17\"\/>\n    <\/svg>\n    <span data-k=\"hoogte\">–<\/span>\n  <\/div>\n\n  <!-- Brandtijd -->\n  <div style=\"display:flex; align-items:center; gap:8px;\">\n    <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\"\n         stroke=\"#5E7361\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n      <path d=\"M8 5h8\"\/>\n      <path d=\"M9 6c0 3 3 4 3 6s-3 3-3 6\"\/>\n      <path d=\"M15 6c0 3-3 4-3 6s3 3 3 6\"\/>\n      <path d=\"M8 19h8\"\/>\n    <\/svg>\n    <span data-k=\"brandtijd\">–<\/span>\n  <\/div>\n\n  <!-- Gewicht -->\n  <div style=\"display:flex; align-items:center; gap:8px;\">\n    <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\"\n         stroke=\"#5E7361\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n      <circle cx=\"12\" cy=\"6.7\" r=\"1.3\"\/>\n      <path d=\"M9 8.5h6\"\/>\n      <path d=\"M7.5 19h9l-1.2-9h-6.6L7.5 19z\"\/>\n    <\/svg>\n    <span data-k=\"gewicht\">–<\/span>\n  <\/div>\n<\/div>\n\n<script type=\"application\/json\" id=\"am-variant-specs-data-{{ section.id }}\">\n{\n  {%- for v in product.variants -%}\n    \"{{ v.id }}\": {\n      \"diameter\": {{ v.metafields.custom.diameter | json }},\n      \"hoogte\": {{ v.metafields.custom.hoogte | json }},\n      \"brandtijd\": {{ v.metafields.custom.brandtijd | json }},\n      \"gewicht\": {{ v.metafields.custom.gewicht | json }}\n    }{% unless forloop.last %},{% endunless %}\n  {%- endfor -%}\n}\n<\/script>\n\n<script>\n(function(){\n  const sectionId = \"{{ section.id }}\";\n  const root = document.getElementById(\"am-variant-specs-\" + sectionId);\n  const dataEl = document.getElementById(\"am-variant-specs-data-\" + sectionId);\n  if (!root || !dataEl) return;\n\n  const data = JSON.parse(dataEl.textContent);\n\n  function getCurrentVariantId(){\n    const form = root.closest('form');\n    const idInput = form ? form.querySelector('input[name=\"id\"]') : document.querySelector('input[name=\"id\"]');\n    return idInput ? idInput.value : null;\n  }\n\n  function render(variantId){\n    const d = data[String(variantId)];\n    if (!d) return;\n    root.querySelectorAll('[data-k]').forEach(el => {\n      const key = el.getAttribute('data-k');\n      const val = (d[key] ?? \"\").toString().trim();\n      el.textContent = val || \"–\";\n    });\n  }\n\n  \/\/ init\n  render(getCurrentVariantId());\n\n  \/\/ triggers\n  document.addEventListener('change', () => render(getCurrentVariantId()));\n  ['variant:change','variant:changed','theme:variant:change','product:variant-change'].forEach(evt => {\n    document.addEventListener(evt, (e) => {\n      const id = e?.detail?.variant?.id || getCurrentVariantId();\n      render(id);\n    });\n  });\n\n  \/\/ fallback: watch hidden input\n  const form = root.closest('form');\n  const idInput = form ? form.querySelector('input[name=\"id\"]') : null;\n  if (idInput) {\n    let prev = idInput.value;\n    setInterval(() => {\n      if (idInput.value !== prev) { prev = idInput.value; render(prev); }\n    }, 200);\n  }\n})();\n<\/script>","show_in_quickbuy":false}},"divider_tbwGrW":{"type":"divider","settings":{"show_in_quickbuy":false}},"inventory_level_LWXzNk":{"type":"inventory-level","settings":{"show_inventory_notice":"low","show_inventory_count":"low","inventory_threshold":10,"enable_box":false,"enable_pulse":true,"show_in_quickbuy":true}},"buy-buttons":{"type":"buy-buttons","settings":{"show_quantity_selector":true,"enable_payment_button":false,"show_backorder_text":true,"show_pickup_availability":true,"show_gift_card_recipient":false}},"image_b7ADDE":{"type":"image","settings":{"image":"{{ product.metafields.custom.maattabel1.value }}","image_width":700,"url":"","open_in_new_tab":false,"show_in_quickbuy":false}}},"block_order":["title","price","divider_wDWKft","description","divider","variant-picker","custom_liquid_eAK7Gg","divider_tbwGrW","inventory_level_LWXzNk","buy-buttons","image_b7ADDE"],"settings":{"show_breadcrumbs":true,"select_first_variant":true,"show_location_underneath":false,"inventory_transfers_enable":true,"enable_st